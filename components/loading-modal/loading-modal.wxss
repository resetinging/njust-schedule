.title {
  font-size: 34rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
}

.progress-bar {
  margin: 16rpx 0;
}

.message {
  font-size: 26rpx;
  color: var(--text-hint);
  display: block;
  margin-top: 12rpx;
}

.spinner {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 24rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--primary);
  animation: bounce 0.6s infinite alternate;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  from { opacity: 0.3; transform: scale(0.8); }
  to { opacity: 1; transform: scale(1.2); }
}
