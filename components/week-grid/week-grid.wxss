/* 周课表网格组件 */

.week-grid {
  background: #fff;
  margin: 12rpx 8rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

/* 表头 */
.grid-header {
  display: flex;
  border-bottom: 2rpx solid #E0E0E0;
  background: #F5F5F5;
  position: sticky;
  top: 0;
  z-index: 5;
}

.header-cell {
  flex: 1;
  text-align: center;
  padding: 14rpx 4rpx;
  font-size: 22rpx;
  font-weight: bold;
  color: var(--text-secondary);
  border-right: 1rpx solid #EEE;
}

.header-cell:last-child {
  border-right: none;
}

.period-header {
  flex: 0 0 60rpx;
  min-width: 60rpx;
}

/* 节次行 */
.grid-body {
  overflow-y: auto;
  max-height: calc(100vh - 200rpx);
}

.period-row {
  display: flex;
  border-bottom: 1rpx solid #F0F0F0;
  min-height: 64rpx;
  position: relative;
}

.period-label {
  flex: 0 0 60rpx;
  min-width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--text-hint);
  background: #FAFAFA;
  border-right: 1rpx solid #EEE;
}

.day-cell {
  flex: 1;
  border-right: 1rpx solid #F5F5F5;
  position: relative;
  min-height: 56rpx;
}

.day-cell:last-child {
  border-right: none;
}

/* 课程块 */
.course-block {
  position: absolute;
  left: 2rpx;
  right: 2rpx;
  top: 0;
  border-radius: 6rpx;
  padding: 4rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  z-index: 2;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.1);
}

.course-name {
  font-size: 20rpx;
  font-weight: 500;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.2;
}

.course-room {
  font-size: 18rpx;
  color: rgba(255,255,255,0.8);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.2;
}
