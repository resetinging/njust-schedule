/* 设置/登录页面样式 */

.container {
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 20rpx;
}

.avatar {
  font-size: 80rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: bold;
}

.user-id {
  font-size: 24rpx;
  color: var(--text-hint);
}

.user-semester {
  font-size: 22rpx;
  color: var(--primary);
  margin-top: 4rpx;
}

/* 操作列表 */
.action-list {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.action-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  font-size: 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.action-item:last-child {
  border-bottom: none;
}

.action-item .arrow {
  color: var(--text-hint);
  font-size: 32rpx;
}

/* 退出登录 */
.logout-area {
  padding: 40rpx 20rpx;
}

.logout-area button {
  font-size: 28rpx;
}

/* 登录表单 */
.login-card {
  margin: 40rpx 20rpx 20rpx;
  padding: 40rpx 32rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 32rpx;
  color: var(--primary);
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #FAFAFA;
}

.login-btn {
  margin-top: 32rpx;
  width: 100%;
  height: 88rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
}

.login-tip {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 24rpx;
}
