/* 课表页面样式 */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
}

/* 顶部信息栏 */
.header {
  background: #fff;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.semester-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.semester-picker {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--primary);
}

.arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
}

.week-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.week-nav {
  display: flex;
  gap: 8rpx;
}

.week-btn {
  display: inline-block;
  padding: 4rpx 12rpx;
  color: var(--primary);
  font-size: 24rpx;
}

.module-box {
  background: #fff;
  margin: 16rpx 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.module-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.module-card {
  padding: 12rpx 0;
}

.module-card-name {
  font-size: 28rpx;
  font-weight: 500;
}

.module-card-detail {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* 课程详情弹窗 */
.modal-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-row .label {
  color: var(--text-hint);
  min-width: 80rpx;
}

.edu-box {
  margin-top: 24rpx;
  padding: 16rpx;
  background: #F3E5F5;
  border-radius: 12rpx;
}

.edu-box text {
  font-size: 24rpx;
  color: var(--primary);
}
